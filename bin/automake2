#!/bin/perl

use 5.006;
use warnings;
use strict;

use File::Basename;

use constant {
    AM_HOME_DIR => dirname(dirname($0)),
    AM_PERL_LIB_DIR => dirname(dirname($0)) . "/perl/lib",
};

use lib AM_PERL_LIB_DIR;

use Automake::Args;
use Automake::Boolean qw(true false);
use Automake::Colors;
use Automake::Diagnostic;
use Automake::Generate;
use Automake::Print;

sub usage ()
{
    print <<'EOF';
Examine Makefile.am input files and generate Makefile.in templates.

Usage:
EOF

    print <<EOF;
  $ARGV_0 [OPTION]...

EOF

    print <<'EOF';
Options:
  -h, --help              Show this help and exit.
  -V, --version           Show version information and exit.
  -q, --quiet             Do not print anything except warnings or errors.
  -n, --no-recurse        Do not recursively descend into subdirectories.
  -C, --chdir=DIR         Change working directory to DIR.

Bug reports can be sent to <rakinar2@osndevs.org>.
EOF
}

sub show_version ()
{
    print <<'EOF';
automake (OSN Autotools2) 2.0.0
License GPLv3+: This is free software.  There is no warranty.
Written by Ar Rakin <rakinar2@osndevs.org>.
EOF
}

my @options = (
    { name => "help", short => "h", argument => ARG_NONE },
    { name => "version", short => "V", argument => ARG_NONE },
    { name => "quiet", short => "q", argument => ARG_NONE },
    { name => "no-recurse", short => "n", argument => ARG_NONE },
    { name => "chdir", short => "C", argument => ARG_REQUIRED },
);

sub custom_opt_handler
{
    my ($is_short, $opt, $val) = @_;

    if ($opt ne "Werror" && $val) {
        print STDERR "$BOLD$ARGV_0:$RESET Option -" . ($is_short ? "" : "-") . "$opt does not accept an argument\n";
        print STDERR "$BOLD$ARGV_0:$RESET Try '$ARGV_0 --help' for more information.\n";
        exit 1;
    }

    if ($opt =~ /^W(no-)?/) {
        my $negate = $opt =~ /^Wno-/ ? true : false;
        my $wname = substr ($opt, $negate ? 4 : 1);

        if (!$negate && $wname eq "error") {
            if ($val && !grep { $_ eq $val } @VALID_WARNINGS) {
                pr_err ("Invalid warning type: $val");
                exit 1;
            }

            set_werror ($val ? $val : true);
            return true;
        }

        if (!grep { $_ eq $wname } @VALID_WARNINGS) {
            pr_err ("Invalid warning type: $wname");
            exit 1;
        }

        set_warning ($wname, !$negate);
        return true;
    }

    return false;
}

my ($argv_ref, $optargs_ref) = getopt_long (\@options, true, \&custom_opt_handler);

if ($optargs_ref->{"help"}) {
    usage ();
    exit 0;
}

if ($optargs_ref->{"version"}) {
    show_version ();
    exit 0;
}

my $flag_no_recurse = $optargs_ref->{"no_recurse"};
my $chdir = exists $optargs_ref->{chdir} && $optargs_ref->{chdir} ? $optargs_ref->{chdir} : "";
my $input_file = "Makefile.am";
my $output_file = "Makefile.in";
my $pwd = ".";

if ($chdir) {
    if (!chdir ($chdir)) {
        pr_err ("Failed to change directory to: $chdir: $!");
        exit 1;
    }

    $pwd = $chdir;
}

my @am_files = glob (AM_HOME_DIR . "/am/*");
my @dir_list = ($pwd);
my $is_err = false;

sub traverse
{
    my ($wd) = @_;
    pr_msg ("Entering directory: $wd");

    my ($warnings, $errors, $next_dirs, $success, $errmsg) = gen_template ($wd, $input_file, $output_file, \@am_files);

    if (!$success) {
        pr_err ("$errmsg");
        $is_err = true;
    }

    foreach my $warning (@$warnings) {
        print_warning (@{$warning}[4], @{$warning}[3], @{$warning}[2], @{$warning}[0] . ":" . @{$warning}[1], @{$warning}[5]);
    }

    foreach my $error (@$errors) {
        print_error (@{$error}[4], @{$error}[3], @{$error}[2], @{$error}[0] . ":" . @{$error}[1], @{$error}[5]);
    }

    foreach my $subdir_data (@$next_dirs) {
        my $subdir = @{$subdir_data}[2];
        traverse (($wd eq "." ? "" : "$wd/") . "$subdir");
    }

    pr_msg ("Leaving directory: $wd");
}

traverse ($pwd);
print_summary ();

if ($is_err || $DIAG_ERROR_COUNT > 0) {
    exit 1;
}
