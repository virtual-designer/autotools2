#!/bin/sh

me=`basename "$0"`
AC_HOME_DIR=`readlink -f "$0"`
AC_HOME_DIR=`dirname "$AC_HOME_DIR"`
AC_HOME_DIR=`dirname "$AC_HOME_DIR"`

color=0
test -t 1 && test -t 2 && color=1

BOLD=""
RESET=""

if test "$color" -eq 1; then
    BOLD="\033[1m"
    RESET="\033[0m"
fi

pr_err ()
{
	format="$1"
	shift
	printf "$me: $format\n" "$@" >&2
}

show_version ()
{
	echo "autoconf (OSN autotools2) 3.0.0"
	echo "License GPLv3+: This is free software.  There is no warranty."
	echo "Written by Ar Rakin <rakinar2@osndevs.org>."
}

cwd=""

while test $# -gt 0; do
	case "$1" in
		-V|--version)
			show_version
			exit 0
			;;

		-C|--change-directory)
			cwd="$2"
			test -z "$cwd" && pr_err "Option '$1' requires an argument" && exit 1
			cwd="$cwd/"
			shift 2
			;;

		--)
			shift
			break
			;;

		-*)
			pr_err "Invalid option '%s'" "$1"
			exit 1
			;;

		*)
			break
			;;
	esac
done

if test $# -gt 0; then
	pr_err "Invalid argument '%s'" "$1"
	exit 1
fi

: ${M4:=m4}
: ${TMPDIR:=/tmp}

aux_install_list=`echo "mkstemp(\\\`${TMPDIR}/autoconf3tmp_XXXXXX')" | $M4`

rm -f "$aux_install_list"
mkfifo "$aux_install_list"
tmp=`mktemp`
pids=''

trap 'code=$?; rm -f "$tmp" "$aux_install_list"; test -n "$pids" && kill -TERM $pids > /dev/null 2>&1; exit $code' EXIT INT TERM

printf "$BOLD$me:$RESET Processing configure.ac\n"

aclocal_m4_include=
test -f "${cwd}aclocal.m4" && aclocal_m4_include="${cwd}aclocal.m4"

{
    while read -r line; do
        file=`printf '%s\n' "$line" | cut -d'|' -f1`
        line_num=`printf '%s\n' "$line" | cut -d'|' -f2`
        script=`printf '%s\n' "$line" | cut -d'|' -f3-`

        if test -f "$script"; then
            continue
        fi

        printf "${BOLD}%s:%d:${RESET} Installing '%s'\n" "$file" "$line_num" "$script"
        script_name=`basename "$script"`
        script_dir=`dirname "$script"`
        "${AC_HOME_DIR}/libexec/install-aux-script" -D -i "$script_name" "$script_dir"
    done < "$aux_install_list"
} &

pids="${pids} $!"

$M4 \
	-D AC_AUTOCONF_V3=1 \
	-D AUTOCONF_PATH="$0" \
    -D _AC_AUX_INSTALL_LIST_PIPE="$aux_install_list" \
	-P \
	-I "$AC_HOME_DIR/m4" \
	-I "$AC_HOME_DIR/m4/autoconf" \
	"$AC_HOME_DIR/m4/autoconf/entry.m4" \
	$aclocal_m4_include "${cwd}configure.ac" > "$tmp" || exit $?

awk -v COLOR="$color" '
	BEGIN {
		for (i = 2; i < ARGC; i++)
			files[i] = ARGV[i];

        MAGENTA = "\033[35m";
        BOLD = "\033[1m";
        WHITE = "\033[37m";
        RESET = "\033[0m";
        DIM = "\033[2m";
        GREY = "\033[2m";

        if (COLOR == 0) {
            MAGENTA = BOLD = GREY = WHITE = RESET = DIM = "";
        }
	}

    END {
        if (warnings > 0)
            printf BOLD "%d warning%s generated.\n" RESET, warnings, (warnings > 1 ? "s" : "") > "/dev/stderr";
    }

	/^ *$/ && ignore == 0 {
		next;
	}

	FILENAME == ARGV[1] {
		ignore = 1;
		line = $0;

		while (match (line, /_?(AC|AS|AM)_[A-Za-z0-9_]+/)) {
			macro = substr ($0, RSTART, RLENGTH);
            gsub (/^[[:space:]]+|[[:space:]]+$/, "", macro);

			if (macro ~ /^[[:space:]]*_/) {
				line = substr (line, RSTART + RLENGTH);
				continue;
			}

			print BOLD "configure:" FNR ": " RESET BOLD MAGENTA "warning: " RESET "Possible use of undefined macro '"'"'" macro "'"'"', not expanded" > "/dev/stderr";
			line = substr (line, RSTART + RLENGTH);
            warnings++;

			for (key in files) {
				file = files[key];
				line_num = 1;
                last_line_src = "";

				while ((getline line_src < file) > 0) {
					if (line_src ~ macro) {
						print BOLD file ":" line_num ": " RESET BOLD GREY "note: " RESET "Possible source of unexpanded macro" > "/dev/stderr";

                        if (line_num > 1) {
                            printf DIM " %4d |" RESET " %s\n", (line_num - 1), last_line_src > "/dev/stderr";
                        }

                        printf BOLD DIM " %4d |" RESET " %s\n", line_num, line_src > "/dev/stderr";
                        line_len = length (line_src) - 1;
                        ln_num_spaces = line_num < 9999 ? 6 : ((log (line_num) / 2) + 2);

                        for (i = 0; i < ln_num_spaces; i++) {
                            printf " " > "/dev/stderr";
                        }

                        printf DIM "| ^" > "/dev/stderr";

                        while (line_len--) {
                            printf "~" > "/dev/stderr";
                        }

                        printf RESET "\n" > "/dev/stderr";
					}

					line_num++;
                    last_line_src = line_src;
			    }

				close (file);
			}
		}
	}
' "$tmp" "${cwd}configure.ac" || exit $?
mv "$tmp" "${cwd}configure" || exit $?
chmod 0755 "${cwd}configure" || exit $?
