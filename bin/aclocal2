#!/bin/sh

me=`basename "$0"`
AM_HOME_DIR=`readlink -f "$0"`
AM_HOME_DIR=`dirname "$AM_HOME_DIR"`
AM_HOME_DIR=`dirname "$AM_HOME_DIR"`

color=0
test -t 1 && test -t 2 && color=1

nl='
'
tab='	'
spc=' '

IFS="${spc}${tab}${nl}"

pr_err ()
{
	format="$1"
	shift
	printf "$me: $format\n" "$@" >&2
}

show_version ()
{
	echo "aclocal (OSN autotools2) 2.0.0"
	echo "License GPLv3+: This is free software.  There is no warranty."
	echo "Written by Ar Rakin <rakinar2@osndevs.org>."
}

usage ()
{
    cat <<EOF
Generate a local macro bundle file for Autoconf.

Usage:
  $0 [OPTION]... [FILE...]

Options:
  -h, --help              Show this help and exit.
  -V, --version           Show version information.
  -I, --include=<PATH>    Add a macro include path.

Send bug reports to <rakinar2@osndevs.org>.
EOF
}

include_path=""

while test $# -gt 0; do
	case "$1" in
		-V|--version)
			show_version
			exit 0
			;;

        -h|--help)
            usage
            exit 0
            ;;

        -I|--include)
            test -z "$2" && pr_err "Option '$1' requires an argument" && exit 1
            include_path="${include_path} $2"
            shift 2
            ;;

		--)
			shift
			break
			;;

		-*)
			pr_err "Invalid option '%s'" "$1"
			exit 1
			;;

		*)
			break
			;;
	esac
done

files="$@"

for ipath in $include_path; do
    for file in "${ipath}/"*.m4; do
        test "$file" = "${ipath}/"'*'".m4" && continue
        files="${files} ${file}"
    done
done

echo "" > "aclocal.m4"

for file in "${AM_HOME_DIR}/m4/automake/"*.m4 $files; do
    cat "$file" >> "aclocal.m4"
    echo "" >> "aclocal.m4"
    echo "" >> "aclocal.m4"
done
