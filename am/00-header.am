am_v_echo_ar_0       = @echo "  AR        $@";
am_v_echo_install_0  = @echo "  INSTALL   $@";
am_v_echo_mkdir_0    = @echo "  MKDIR     $@";
am_v_echo_mkdir_p_0  = @echo "  MKDIR [P] $@";
